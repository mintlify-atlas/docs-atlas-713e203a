  "keyFeatures": [
    "Low-latency game streaming with hardware encoding support",
    "Multi-platform support (Linux, Windows, macOS, FreeBSD)",
    "Hardware encoder support for AMD, Intel, and Nvidia GPUs",
    "Web UI for configuration and client pairing",
    "RESTful API for automation and integration",
    "Docker deployment support",
    "Gamepad emulation for multiple controller types",
    "Multiple screen capture methods per platform",
    "UPnP/NAT traversal support",
    "HDR and 4K streaming capabilities"
  ],
  "publicApiSurface": [
    "GET /api/apps - List configured applications",
    "POST /api/apps - Save application configuration",
    "POST /api/apps/close - Close running application",
    "DELETE /api/apps/{index} - Delete application",
    "GET /api/clients/list - List paired clients",
    "POST /api/clients/unpair - Unpair a client",
    "POST /api/clients/unpair-all - Unpair all clients",
    "GET /api/config - Get configuration",
    "POST /api/config - Update configuration",
    "GET /api/configLocale - Get locale configuration",
    "GET /api/covers/{index} - Get application cover image",
    "POST /api/covers/upload - Upload cover image",
    "GET /api/logs - Get system logs",
    "POST /api/password - Update admin password",
    "POST /api/pin - Save pairing PIN",
    "POST /api/reset-display-device-persistence - Reset display settings",
    "POST /api/restart - Restart Sunshine service",
    "GET /api/vigembus/status - Get ViGEmBus status (Windows)",
    "POST /api/vigembus/install - Install ViGEmBus (Windows)"
  ]
